# CityMind — Environment Variables
# Copy this file to .env and fill in your values.

# ── Optional: Anthropic API (only needed for LLM features, not for data queries) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: LangSmith tracing ──────────────────────────────────────────────
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_TRACING=true

# ── Backend URL (used by frontend proxy in development) ──────────────────────
FASTAPI_URL=http://localhost:8000

# ── Database paths (defaults shown — override only if you move the DB files) ─
# REPLICA_DB_PATH=backend/db/opendata_replica.db
# AUDIT_DB_PATH=backend/db/audit.db

# ── Sync settings ────────────────────────────────────────────────────────────
# SYNC_PAGE_SIZE=2000       # ArcGIS records per request (max 2000)
# SYNC_TIMEOUT_SECONDS=60   # HTTP timeout for ArcGIS requests
